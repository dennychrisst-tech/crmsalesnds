# Supabase — ambil dari Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service role key — HANYA untuk server-side (admin API). JANGAN expose ke client!
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# URL publik app — dipakai untuk redirect URL pada invite email
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
