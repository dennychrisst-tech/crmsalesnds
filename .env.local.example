# Supabase PostgreSQL — ambil dari Supabase Dashboard > Project Settings > Database
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.[ref]:[password]@[host]:6543/postgres?pgbouncer=true

# Direct connection URL (untuk prisma migrate deploy — tanpa pgbouncer)
DIRECT_URL=postgresql://postgres.[ref]:[password]@[host]:5432/postgres

# JWT secret untuk session cookie — generate dengan: openssl rand -base64 32
JWT_SECRET=your-random-secret-here

# Supabase — hanya untuk file storage (opsional, jika pakai attachment)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]
SUPABASE_SERVICE_ROLE_KEY=[service-role-key]

# Web Push (reminder notifications) — generate dengan: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Harus mailto: atau https: — dipakai web-push untuk identifikasi pengirim
VAPID_SUBJECT=mailto:you@example.com

# Secret yang harus sama dengan yang di-set di Vercel Cron Jobs settings —
# Vercel otomatis kirim ini sebagai header Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
