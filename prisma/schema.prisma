generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("employee")
  created_at    DateTime @default(now())

  @@map("users")
}

model Client {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  sector       String   @default("Banking")
  pic          Json     @default("[]")
  contact      String   @default("")
  status       String   @default("Prospect")
  notes        String   @default("")
  address      String   @default("")
  website      String   @default("")
  company_size String   @default("")
  logo_url     String?
  created_by_id String? @db.Uuid
  created_at   DateTime @default(now())

  contacts    Contact[]
  visits      Visit[]
  deals       Deal[]
  projects    Project[]
  tasks       Task[]
  activities  Activity[]
  attachments Attachment[]

  @@map("clients")
}

model Contact {
  id            String   @id @default(uuid()) @db.Uuid
  client_id     String   @db.Uuid
  name          String   @default("")
  title         String   @default("")
  email         String   @default("")
  phone         String   @default("")
  notes         String   @default("")
  created_by_id String?  @db.Uuid
  created_at    DateTime @default(now())

  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@map("contacts")
}

model Visit {
  id            String    @id @default(uuid()) @db.Uuid
  client_id     String    @db.Uuid
  deal_id       String?   @db.Uuid
  project       String?
  date          DateTime  @db.Date
  purpose       String    @default("")
  approach      String    @default("")
  status        String    @default("Planned")
  pic           String    @default("")
  pic_client    String    @default("")
  jabatan       String    @default("")
  followup_date DateTime? @db.Date
  summary       String    @default("")
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  client Client @relation(fields: [client_id], references: [id], onDelete: Cascade)
  deal   Deal?  @relation(fields: [deal_id], references: [id], onDelete: SetNull)

  @@index([client_id])
  @@index([deal_id])
  @@index([status])
  @@index([date])
  @@map("visits")
}

model Deal {
  id               String    @id @default(uuid()) @db.Uuid
  name             String
  client_id        String    @db.Uuid
  value            BigInt    @default(0)
  stage            String    @default("Approching")
  deal_type        String    @default("")
  product          String    @default("")
  close_date       DateTime? @db.Date
  notes            String    @default("")
  owner            String    @default("")
  win_loss_reason  String    @default("")
  competitor       String    @default("")
  stage_updated_at DateTime?
  created_by_id    String?   @db.Uuid
  created_at       DateTime  @default(now())

  client      Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  documents   Document[]
  attachments Attachment[]
  activities  Activity[]
  tasks       Task[]
  visits      Visit[]

  @@index([client_id])
  @@index([stage])
  @@map("deals")
}

model Project {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  client_id     String    @db.Uuid
  product       String    @default("")
  status        String    @default("Initiation")
  value         BigInt    @default(0)
  golive        DateTime? @db.Date
  notes         String    @default("")
  partner       String?
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  client      Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  talentRoles TalentRole[]

  @@index([client_id])
  @@map("projects")
}

// Talent (outsourcing/staffing) tracking — a Project with product = "Talent" can
// have several requisition batches ("rows" in the team's Excel tracker), each
// for one role. CV outcomes are tallied as counts (matching the Excel columns)
// rather than individual candidate records.
model TalentRole {
  id              String    @id @default(uuid()) @db.Uuid
  project_id      String    @db.Uuid
  name            String    @default("") // "Name Project" in the Excel — batch title + running log
  role_name       String
  level           String    @default("")
  ratecard        BigInt    @default(0)
  pic             String    @default("")
  deadline        DateTime? @db.Date
  status          String    @default("Open")
  req_cv          Int       @default(0)
  cv_submitted    Int       @default(0)
  cv_reject       Int       @default(0)
  cv_not_response Int       @default(0)
  po_issued       Int       @default(0)
  notes           String    @default("")
  created_by_id   String?   @db.Uuid
  created_at      DateTime  @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@map("talent_roles")
}

model Task {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  due_date      DateTime? @db.Date
  client_id     String?   @db.Uuid
  deal_id       String?   @db.Uuid
  pic_client    String    @default("")
  assigned_to   String    @default("")
  status        String    @default("Open")
  notes         String    @default("")
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  client Client? @relation(fields: [client_id], references: [id], onDelete: SetNull)
  deal   Deal?   @relation(fields: [deal_id], references: [id], onDelete: SetNull)

  @@index([client_id])
  @@index([deal_id])
  @@index([due_date])
  @@index([status])
  @@map("tasks")
}

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  category      String   @default("")
  description   String   @default("")
  created_by_id String?  @db.Uuid
  created_at    DateTime @default(now())

  @@map("products")
}

model Document {
  id            String    @id @default(uuid()) @db.Uuid
  deal_id       String    @db.Uuid
  name          String    @default("")
  type          String    @default("Proposal Teknis")
  status        String    @default("Draft")
  date          DateTime? @db.Date
  notes         String    @default("")
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  deal Deal @relation(fields: [deal_id], references: [id], onDelete: Cascade)

  @@index([deal_id])
  @@map("documents")
}

model Attachment {
  id            String   @id @default(uuid()) @db.Uuid
  deal_id       String?  @db.Uuid
  client_id     String?  @db.Uuid
  file_name     String
  file_url      String
  file_size     BigInt   @default(0)
  created_by_id String?  @db.Uuid
  uploaded_at   DateTime @default(now())

  deal   Deal?   @relation(fields: [deal_id], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([deal_id])
  @@index([client_id])
  @@map("attachments")
}

model Activity {
  id            String   @id @default(uuid()) @db.Uuid
  deal_id       String?  @db.Uuid
  client_id     String?  @db.Uuid
  type          String    @default("Note")
  description   String    @default("")
  date          DateTime? @db.Date
  created_by    String    @default("")
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  deal   Deal?   @relation(fields: [deal_id], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([deal_id])
  @@index([client_id])
  @@index([date])
  @@map("activities")
}

model Event {
  id            String    @id @default(uuid()) @db.Uuid
  title         String    @default("")
  date          DateTime  @db.Date
  type          String    @default("Meeting Online")
  description   String    @default("")
  created_by    String    @default("")
  client_id     String?   @db.Uuid
  status        String    @default("Planned")
  followup_date DateTime? @db.Date
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  @@index([client_id])
  @@index([date])
  @@map("events")
}

model AppSetting {
  key        String   @id
  value      String   @default("")
  updated_at DateTime @default(now()) @updatedAt

  @@map("app_settings")
}
