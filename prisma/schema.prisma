generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("employee")
  created_at    DateTime @default(now())

  @@map("users")
}

// Web Push subscriptions for reminder notifications — one row per device a
// user has enabled push on. endpoint is unique so re-subscribing the same
// device (e.g. after clearing site data) upserts instead of duplicating.
model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  endpoint   String   @unique
  p256dh     String
  auth       String
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("push_subscriptions")
}

model Client {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  sector       String   @default("Banking")
  pic          Json     @default("[]")
  contact      String   @default("")
  status       String   @default("Prospect")
  notes        String   @default("")
  address      String   @default("")
  website      String   @default("")
  company_size String   @default("")
  logo_url     String?
  // Ordered list of org-chart tier names for this client (e.g. ["Komisaris",
  // "Direksi", "General Manager", "Manager", "Staff"]) — editable per client
  // since not every company uses the same structure. Row order in the org
  // chart follows this array's order.
  org_levels   Json     @default("[\"Komisaris\", \"Direksi\", \"General Manager\", \"Manager\", \"Staff\"]")
  created_by_id String? @db.Uuid
  created_at   DateTime @default(now())

  contacts    Contact[]
  visits      Visit[]
  deals       Deal[]
  projects    Project[]
  tasks       Task[]
  activities  Activity[]
  attachments Attachment[]

  @@map("clients")
}

model Contact {
  id            String   @id @default(uuid()) @db.Uuid
  client_id     String   @db.Uuid
  name          String   @default("")
  title         String   @default("")
  email         String   @default("")
  phone         String   @default("")
  notes         String   @default("")
  // Org-chart placement — org_level must match one of the client's
  // org_levels entries to show up in that tier (empty/stale = falls back to
  // the "belum dipetakan" pool). org_order sorts contacts left-to-right
  // within the same tier. reports_to_id draws the "lapor ke" connector line;
  // SetNull so deleting a manager just orphans their reports instead of
  // cascading the delete.
  org_level     String   @default("")
  org_order     Int      @default(0)
  reports_to_id String?  @db.Uuid
  created_by_id String?  @db.Uuid
  created_at    DateTime @default(now())

  client       Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  reports_to   Contact?  @relation("ContactReportsTo", fields: [reports_to_id], references: [id], onDelete: SetNull)
  reports      Contact[] @relation("ContactReportsTo")

  @@index([client_id])
  @@index([reports_to_id])
  @@map("contacts")
}

model Visit {
  id            String    @id @default(uuid()) @db.Uuid
  client_id     String    @db.Uuid
  deal_id       String?   @db.Uuid
  project_id    String?   @db.Uuid
  date          DateTime  @db.Date
  purpose       String    @default("")
  approach      String    @default("")
  status        String    @default("Planned")
  pic           String    @default("")
  pic_client    String    @default("")
  jabatan       String    @default("")
  followup_date DateTime? @db.Date
  summary       String    @default("")
  // Points at the new Visit auto-created when this one is marked Reschedule
  // (see VisitModal) — lets re-saving move that same follow-up visit instead
  // of spawning a duplicate each time the reschedule date is edited.
  rescheduled_to_id String? @db.Uuid
  // Reverse of rescheduled_to_id — set on the newly-created follow-up visit so
  // it (and the calendar) can show "this exists because of a reschedule".
  rescheduled_from_id String? @db.Uuid
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  client  Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  deal    Deal?    @relation(fields: [deal_id], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)

  @@index([client_id])
  @@index([deal_id])
  @@index([project_id])
  @@index([status])
  @@index([date])
  @@map("visits")
}

model Deal {
  id               String    @id @default(uuid()) @db.Uuid
  name             String
  client_id        String    @db.Uuid
  value            BigInt    @default(0)
  stage            String    @default("Approching")
  deal_type        String    @default("")
  product          String    @default("")
  close_date       DateTime? @db.Date
  notes            String    @default("")
  owner            String    @default("")
  win_loss_reason  String    @default("")
  competitor       String    @default("")
  stage_updated_at DateTime?
  created_by_id    String?   @db.Uuid
  created_at       DateTime  @default(now())

  // Revenue Forecast opportunity fields — merged in from the old standalone
  // revenue_opportunities table so a deal only ever needs one record (see
  // RevenueForecastView, which now reads its "Opportunity" list from Deal
  // instead of a separate table to avoid the two views drifting out of sync).
  year                        Int?
  category                    String @default("") // H/M/L risk rating
  potentially_billed_amount   BigInt @default(0)
  potentially_billed_percent  Int    @default(0)
  team                        String @default("")
  pmo                         String @default("")
  plan                        String @default("")
  presales                    String @default("")
  sales                       String @default("")
  // True for historical/stale revenue-forecast opportunities (e.g. old Dropped
  // items) that should stay visible in Revenue Forecast but never count toward
  // Dashboard's Win Rate / Pipeline Aktif KPIs.
  archived                    Boolean @default(false)

  client      Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  documents   Document[]
  attachments Attachment[]
  activities  Activity[]
  tasks       Task[]
  visits      Visit[]

  @@index([client_id])
  @@index([stage])
  @@map("deals")
}

model Project {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  client_id     String    @db.Uuid
  product       String    @default("")
  status        String    @default("Initiation")
  value         BigInt    @default(0)
  golive        DateTime? @db.Date
  notes         String    @default("")
  partner       String?
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  client      Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  talentRoles TalentRole[]
  visits      Visit[]

  @@index([client_id])
  @@map("projects")
}

// Talent (outsourcing/staffing) tracking — a Project with product = "Talent" can
// have several requisition batches ("rows" in the team's Excel tracker), each
// for one role. CV outcomes are tallied as counts (matching the Excel columns)
// rather than individual candidate records.
model TalentRole {
  id              String    @id @default(uuid()) @db.Uuid
  project_id      String    @db.Uuid
  role_name       String
  level           String    @default("")
  ratecard        BigInt    @default(0)
  pic             String    @default("")
  deadline        DateTime? @db.Date
  status          String    @default("Open")
  req_cv          Int       @default(0)
  cv_submitted    Int       @default(0)
  cv_reject       Int       @default(0)
  cv_not_response Int       @default(0)
  po_issued       Int       @default(0)
  notes           String    @default("")
  created_by_id   String?   @db.Uuid
  created_at      DateTime  @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@map("talent_roles")
}

model Task {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  due_date      DateTime? @db.Date
  client_id     String?   @db.Uuid
  deal_id       String?   @db.Uuid
  pic_client    String    @default("")
  assigned_to   String    @default("")
  status        String    @default("Open")
  notes         String    @default("")
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  client Client? @relation(fields: [client_id], references: [id], onDelete: SetNull)
  deal   Deal?   @relation(fields: [deal_id], references: [id], onDelete: SetNull)

  @@index([client_id])
  @@index([deal_id])
  @@index([due_date])
  @@index([status])
  @@map("tasks")
}

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  category      String   @default("")
  description   String   @default("")
  created_by_id String?  @db.Uuid
  created_at    DateTime @default(now())

  @@map("products")
}

model Document {
  id            String    @id @default(uuid()) @db.Uuid
  deal_id       String    @db.Uuid
  name          String    @default("")
  type          String    @default("Proposal Teknis")
  status        String    @default("Draft")
  date          DateTime? @db.Date
  notes         String    @default("")
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  deal Deal @relation(fields: [deal_id], references: [id], onDelete: Cascade)

  @@index([deal_id])
  @@map("documents")
}

model Attachment {
  id            String   @id @default(uuid()) @db.Uuid
  deal_id       String?  @db.Uuid
  client_id     String?  @db.Uuid
  file_name     String
  file_url      String
  file_size     BigInt   @default(0)
  created_by_id String?  @db.Uuid
  uploaded_at   DateTime @default(now())

  deal   Deal?   @relation(fields: [deal_id], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([deal_id])
  @@index([client_id])
  @@map("attachments")
}

model Activity {
  id            String   @id @default(uuid()) @db.Uuid
  deal_id       String?  @db.Uuid
  client_id     String?  @db.Uuid
  type          String    @default("Note")
  description   String    @default("")
  date          DateTime? @db.Date
  created_by    String    @default("")
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  deal   Deal?   @relation(fields: [deal_id], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([deal_id])
  @@index([client_id])
  @@index([date])
  @@map("activities")
}

model Event {
  id            String    @id @default(uuid()) @db.Uuid
  title         String    @default("")
  date          DateTime  @db.Date
  type          String    @default("Meeting Online")
  description   String    @default("")
  created_by    String    @default("")
  client_id     String?   @db.Uuid
  status        String    @default("Planned")
  followup_date DateTime? @db.Date
  created_by_id String?   @db.Uuid
  created_at    DateTime  @default(now())

  @@index([client_id])
  @@index([date])
  @@map("events")
}

model AppSetting {
  key        String   @id
  value      String   @default("")
  updated_at DateTime @default(now()) @updatedAt

  @@map("app_settings")
}

// Security/admin audit trail — separate from the business-facing Activity log.
// Tracks sensitive admin actions (user create/role-change/delete, settings
// change, data export, failed logins) so "who changed/deleted what" can be
// investigated. Failed-login rows also back the login rate-limiting check.
model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actor_id    String?  @db.Uuid
  actor_name  String   @default("")
  actor_email String   @default("")
  action      String
  target      String   @default("")
  details     Json     @default("{}")
  ip          String   @default("")
  created_at  DateTime @default(now())

  @@index([created_at])
  @@index([action])
  @@map("audit_logs")
}

// Revenue Forecast — company-wide annual target vs. contracted-revenue vs.
// opportunity-pipeline tracker (mirrors the team's yearly forecast workbook).
model RevenueTarget {
  id               String   @id @default(uuid()) @db.Uuid
  year             Int      @unique
  target_revenue   BigInt   @default(0)
  total_mandays    Int      @default(0)
  mandays_per_year Int      @default(0)
  rate             BigInt   @default(0)
  resource_count   Int      @default(0)
  created_by_id    String?  @db.Uuid
  created_at       DateTime @default(now())

  @@map("revenue_targets")
}

// One row per contracted line item (Project / Maintenance / Other), grouping
// its invoicing milestones. Milestones (label/percent/amount/target month/
// status) are stored as JSON since they're always read and edited together
// with their parent line, not queried independently — no separate table needed.
model RevenueLine {
  id            String   @id @default(uuid()) @db.Uuid
  year          Int
  category      String   @default("Project")
  project_name  String
  pic           String   @default("")
  milestones    Json     @default("[]")
  notes         String   @default("")
  // Set when this line was auto-generated from a Deal reaching Kontrak stage
  // (see useData's updateDealStage/upsertDeal) — lets that hand-off check
  // whether a line already exists for a deal before creating another one.
  deal_id       String?  @db.Uuid
  created_by_id String?  @db.Uuid
  created_at    DateTime @default(now())

  @@index([year])
  @@map("revenue_lines")
}

// Pipeline of unclosed revenue opportunities — status tracks whether it's
// still Active, put on Hold, or Dropped (each with its own reason).
model RevenueOpportunity {
  id                          String    @id @default(uuid()) @db.Uuid
  year                        Int
  project_name                String
  pic                         String    @default("")
  category                    String    @default("L")
  amount                      BigInt    @default(0)
  target_closing_date         DateTime? @db.Date
  team                        String    @default("")
  pmo                         String    @default("")
  plan                        String    @default("")
  product                     String    @default("")
  potentially_billed_amount   BigInt    @default(0)
  potentially_billed_percent  Int       @default(0)
  presales                    String    @default("")
  sales                       String    @default("")
  status                      String    @default("Active")
  reason                      String    @default("")
  notes                       String    @default("")
  created_by_id               String?   @db.Uuid
  created_at                  DateTime  @default(now())

  @@index([year])
  @@map("revenue_opportunities")
}

// Internal rate-card benchmark per resource role (COGS / Low / Medium / Max
// price). One row per role — shared reference used to judge whether a
// client's actual rate (MandaysClientRate) is competitive or under/over-priced.
model MandaysRole {
  id            String   @id @default(uuid()) @db.Uuid
  role_name     String   @unique
  cogs          BigInt   @default(0)
  low_rate      BigInt   @default(0)
  med_rate      BigInt   @default(0)
  max_price     BigInt   @default(0)
  created_by_id String?  @db.Uuid
  created_at    DateTime @default(now())

  client_rates MandaysClientRate[]

  @@map("mandays_roles")
}

// One actual/quoted rate for a role at a specific client + contract period
// (e.g. "DBS OBID Propose Rate 2025"), plus where it falls relative to the
// role's Low/Medium/Max bands. client_label is free text (not a Client FK)
// since this is a standalone rate-benchmark reference, not a CRM relationship.
model MandaysClientRate {
  id             String   @id @default(uuid()) @db.Uuid
  role_id        String   @db.Uuid
  client_label   String
  rate_label     String
  rate_value     BigInt   @default(0)
  classification String   @default("")
  notes          String   @default("")
  created_by_id  String?  @db.Uuid
  created_at     DateTime @default(now())

  role MandaysRole @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@index([role_id])
  @@map("mandays_client_rates")
}
